# Supabase Database Configuration
# Dapatkan dari: Settings → Database → Connection string
DB_HOST=your-supabase-host.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-database-password

# JWT Secret (ubah dengan random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Google Sheets Webhook URL
# Dapatkan dari Apps Script → Deploy → Web app URL
GOOGLE_SHEETS_WEBHOOK_URL=your-google-apps-script-webhook-url

# Admin Credentials
# Default: admin / admin123
ADMIN_USERNAME=admin
# Default password hash for 'admin123'
# Generate new hash dengan: node -e "const bcrypt = require('bcryptjs'); console.log(bcrypt.hashSync('yourpassword', 10))"
ADMIN_PASSWORD_HASH=$2a$10$8fKr5qKxQjKxQjKxQjKxQO5vXjKxQjKxQjKxQjKxQjKxQjKxQjK

# Server Port
PORT=3000

